{
  "name": "time-tracker",
  "version": "1.0.0",
  "description": "Time Tracker PWA Application",
  "main": "index.js",
  "scripts": {
    "start": "parcel src/time-tracker-pwa/index.html",
    "build": "node build.js",
    "build:parcel": "parcel build src/time-tracker-pwa/index.html --public-url ./",
    "validate:pwa": "echo Run 'npm run start' in one terminal, then run: npx lighthouse http://localhost:1234 --only-categories=pwa,performance,accessibility,best-practices --view",
    "package:zip": "npm run build && npx bestzip time-tracker-pwa-dist.zip dist/*",
    "cap:init": "npx cap init time-tracker com.conciseways.timetracker --web-dir=dist",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "build:mobile": "npm run build && npm run cap:copy && npm run cap:sync",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "fast-tracker",
    "html",
    "application"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/cli": "8.1.0",
    "bestzip": "^2.2.1",
    "lighthouse": "^12.0.0",
    "parcel-bundler": "^1.12.5"
  },
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/ios": "^5.0.0",
    "@js-temporal/polyfill": "0.5.1"
  }
}
