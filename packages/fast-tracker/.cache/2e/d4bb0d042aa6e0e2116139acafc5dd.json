nter;\r\n    }\r\n    \r\n    h1, h2, h3 {\r\n      color: var(--secondary-color);\r\n    }\r\n    \r\n    header h1 {\r\n      color: var(--light-text);\r\n      margin: 0;\r\n    }\r\n    \r\n    .container {\r\n      display: grid;\r\n      grid-template-columns: 250px 1fr;\r\n      gap: 2rem;\r\n    }\r\n    \r\n    .sidebar {\r\n      background-color: var(--dark-bg);\r\n      color: var(--light-text);\r\n      padding: 1.5rem;\r\n      border-radius: var(--border-radius);\r\n      height: fit-content;\r\n    }\r\n    \r\n    .sidebar ul {\r\n      list-style: none;\r\n      padding: 0;\r\n      margin: 0;\r\n    }\r\n    \r\n    .sidebar li {\r\n      margin-bottom: 0.5rem;\r\n      padding: 0.5rem;\r\n      border-radius: 4px;\r\n      cursor: pointer;\r\n      transition: background-color 0.3s;\r\n    }\r\n    \r\n    .sidebar li:hover, .sidebar li.active {\r\n      background-color: rgba(255, 255, 255, 0.1);\r\n    }\r\n    \r\n    .sidebar li.active {\r\n      background-color: var(--primary-color);\r\n    }\r\n    \r\n    .content {\r\n      background-color: white;\r\n      padding: 2rem;\r\n      border-radius: var(--border-radius);\r\n      box-shadow: var(--box-shadow);\r\n    }\r\n    \r\n    .section {\r\n      display: none;\r\n    }\r\n    \r\n    .section.active {\r\n      display: block;\r\n    }\r\n    \r\n    .form-group {\r\n      margin-bottom: 1.5rem;\r\n    }\r\n    \r\n    .form-group label {\r\n      display: block;\r\n      margin-bottom: 0.5rem;\r\n      font-weight: 500;\r\n    }\r\n    \r\n    .form-group input, .form-group select {\r\n      width: 100%;\r\n      padding: 0.5rem;\r\n      border: 1px solid #ddd;\r\n      border-radius: 4px;\r\n      font-size: 1rem;\r\n    }\r\n    \r\n    button {\r\n      background-color: var(--primary-color);\r\n      color: white;\r\n      border: none;\r\n      padding: 0.5rem 1rem;\r\n      border-radius: 4px;\r\n      cursor: pointer;\r\n      font-weight: 500;\r\n      transition: background-color 0.3s;\r\n    }\r\n    \r\n    button:hover {\r\n      background-color: #2980b9;\r\n    }\r\n    \r\n    .result {\r\n      margin-top: 1.5rem;\r\n      padding: 1rem;\r\n      background-color: var(--light-bg);\r\n      border-radius: var(--border-radius);\r\n      border-left: 4px solid var(--primary-color);\r\n    }\r\n    \r\n    .result pre {\r\n      margin: 0;\r\n      white-space: pre-wrap;\r\n      font-family: monospace;\r\n    }\r\n    \r\n    .timezone-grid {\r\n      display: grid;\r\n      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\r\n      gap: 1rem;\r\n      margin-top: 1rem;\r\n    }\r\n    \r\n    .timezone-card {\r\n      background-color: var(--light-bg);\r\n      padding: 1rem;\r\n      border-radius: var(--border-radius);\r\n      box-shadow: var(--box-shadow);\r\n    }\r\n    \r\n    .timezone-card h4 {\r\n      margin-top: 0;\r\n      color: var(--primary-color);\r\n    }\r\n    \r\n    .inline-form {\r\n      display: flex;\r\n      gap: 1rem;\r\n      align-items: flex-end;\r\n    }\r\n    \r\n    .inline-form .form-group {\r\n      flex: 1;\r\n    }\r\n    \r\n    .inline-form button {\r\n      height: 38px;\r\n    }\r\n    \r\n    /* Time Tracker Styles */\r\n    .button-group {\r\n      display: flex;\r\n      gap: 1rem;\r\n      margin-bottom: 2rem;\r\n    }\r\n    \r\n    .time-entries-container {\r\n      margin-top: 1.5rem;\r\n      margin-bottom: 2rem;\r\n      overflow-x: auto;\r\n    }\r\n    \r\n    #time-entries-table {\r\n      width: 100%;\r\n      border-collapse: collapse;\r\n      margin-bottom: 1.5rem;\r\n    }\r\n    \r\n    #time-entries-table th,\r\n    #time-entries-table td {\r\n      padding: 0.75rem;\r\n      text-align: left;\r\n      border-bottom: 1px solid #ddd;\r\n    }\r\n    \r\n    #time-entries-table th {\r\n      background-color: var(--light-bg);\r\n      font-weight: 600;\r\n    }\r\n    \r\n    #time-entries-table tr:hover,\r\n    #saved-entries-table tr:hover {\r\n      background-color: rgba(52, 152, 219, 0.05);\r\n    }\r\n    \r\n    .entry-actions {\r\n      display: flex;\r\n      gap: 0.5rem;\r\n    }\r\n    \r\n    .entry-actions button,\r\n    .delete-entry-btn {\r\n      padding: 0.25rem 0.5rem;\r\n      font-size: 0.875rem;\r\n      background-color: var(--accent-color);\r\n      border: none;\r\n      border-radius: 4px;\r\n      color: white;\r\n      cursor: pointer;\r\n    }\r\n    \r\n    .edit-btn {\r\n      background-color: var(--primary-color);\r\n    }\r\n    \r\n    .delete-btn {\r\n      background-color: var(--accent-color);\r\n    }\r\n    \r\n    .saved-entries-container {\r\n      margin-top: 1.5rem;\r\n      margin-bottom: 2rem;\r\n      overflow-x: auto;\r\n    }\r\n    \r\n    #saved-entries-table {\r\n      width: 100%;\r\n      border-collapse: collapse;\r\n      margin-bottom: 1.5rem;\r\n    }\r\n    \r\n    #saved-entries-table th,\r\n    #saved-entries-table td {\r\n      padding: 0.75rem;\r\n      text-align: left;\r\n      border-bottom: 1px solid #ddd;\r\n    }\r\n    \r\n    #saved-entries-table th {\r\n      background-color: var(--light-bg);\r\n      font-weight: 600;\r\n    }\r\n    \r\n    textarea {\r\n      width: 100%;\r\n      min-height: 80px;\r\n      padding: 0.5rem;\r\n      border: 1px solid #ddd;\r\n      border-radius: 4px;\r\n      font-family: inherit;\r\n      resize: vertical;\r\n    }\r\n    \r\n    @media (max-width: 768px) {\r\n      .container {\r\n        grid-template-columns: 1fr;\r\n      }\r\n      \r\n      .inline-form {\r\n        flex-direction: column;\r\n      }\r\n      \r\n      .inline-form button {\r\n        width: 100%;\r\n      }\r\n    }</style>\r\n</head>\r\n<body>\r\n  <header>\r\n    <h1>Temporal API Explorer</h1>\r\n    <div>\r\n      <span id=\"current-time\"></span>\r\n    </div>\r\n  </header>\r\n  \r\n  <div class=\"container\">\r\n    <div class=\"sidebar\">\r\n      <ul>\r\n        <li data-section=\"now\" class=\"active\">Current Date & Time</li>\r\n        <li data-section=\"create\">Create Date & Time</li>\r\n        <li data-section=\"timezone\">Time Zone Handling</li>\r\n        <li data-section=\"arithmetic\">Date/Time Arithmetic</li>\r\n        <li data-section=\"duration\">Durations</li>\r\n        <li data-section=\"calendar\">Calendars</li>\r\n        <li data-section=\"practical\">Practical Examples</li>\r\n        <li data-section=\"timetracker\">Time Tracker</li>\r\n      </ul>\r\n    </div>\r\n    \r\n    <div class=\"content\">\r\n      <!-- Current Date & Time Section -->\r\n      <div id=\"now\" class=\"section active\">\r\n        <h2>Current Date & Time</h2>\r\n        <p>Explore the current date and time in different Temporal formats.</p>\r\n        \r\n        <button id=\"refresh-now\">Refresh</button>\r\n        \r\n        <div class=\"result\">\r\n          <pre id=\"now-result\"></pre>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Create Date & Time Section -->\r\n      <div id=\"create\" class=\"section\">\r\n        <h2>Create Date & Time</h2>\r\n        <p>Create dates and times in different Temporal formats.</p>\r\n        \r\n        <h3>Create a Date</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"create-year\">Year</label>\r\n            <input type=\"number\" id=\"create-year\" value=\"2023\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"create-month\">Month</label>\r\n            <input type=\"number\" id=\"create-month\" min=\"1\" max=\"12\" value=\"1\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"create-day\">Day</label>\r\n            <input type=\"number\" id=\"create-day\" min=\"1\" max=\"31\" value=\"1\">\r\n          </div>\r\n          <button id=\"create-date-btn\">Create Date</button>\r\n        </div>\r\n        \r\n        <h3>Create a Time</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"create-hour\">Hour</label>\r\n            <input type=\"number\" id=\"create-hour\" min=\"0\" max=\"23\" value=\"12\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"create-minute\">Minute</label>\r\n            <input type=\"number\" id=\"create-minute\" min=\"0\" max=\"59\" value=\"0\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"create-second\">Second</label>\r\n            <input type=\"number\" id=\"create-second\" min=\"0\" max=\"59\" value=\"0\">\r\n          </div>\r\n          <button id=\"create-time-btn\">Create Time</button>\r\n        </div>\r\n        \r\n        <h3>Create a DateTime</h3>\r\n        <div class=\"form-group\">\r\n          <label for=\"create-iso\">ISO String (e.g., 2023-01-01T12:00:00)</label>\r\n          <input type=\"text\" id=\"create-iso\" value=\"2023-01-01T12:00:00\">\r\n        </div>\r\n        <button id=\"create-datetime-btn\">Create DateTime</button>\r\n        \r\n        <div class=\"result\">\r\n          <pre id=\"create-result\"></pre>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Time Zone Handling Section -->\r\n      <div id=\"timezone\" class=\"section\">\r\n        <h2>Time Zone Handling</h2>\r\n        <p>Explore how Temporal handles different time zones.</p>\r\n        \r\n        <div class=\"form-group\">\r\n          <label for=\"timezone-datetime\">DateTime (ISO String)</label>\r\n          <input type=\"text\" id=\"timezone-datetime\" value=\"2023-01-01T12:00:00\">\r\n        </div>\r\n        \r\n        <div class=\"timezone-grid\">\r\n          <div class=\"timezone-card\">\r\n            <h4>New York</h4>\r\n            <button class=\"timezone-btn\" data-timezone=\"America/New_York\">Show</button>\r\n            <div class=\"timezone-result\"></div>\r\n          </div>\r\n          <div class=\"timezone-card\">\r\n            <h4>London</h4>\r\n            <button class=\"timezone-btn\" data-timezone=\"Europe/London\">Show</button>\r\n            <div class=\"timezone-result\"></div>\r\n          </div>\r\n          <div class=\"timezone-card\">\r\n            <h4>Tokyo</h4>\r\n            <button class=\"timezone-btn\" data-timezone=\"Asia/Tokyo\">Show</button>\r\n            <div class=\"timezone-result\"></div>\r\n          </div>\r\n          <div class=\"timezone-card\">\r\n            <h4>Sydney</h4>\r\n            <button class=\"timezone-btn\" data-timezone=\"Australia/Sydney\">Show</button>\r\n            <div class=\"timezone-result\"></div>\r\n          </div>\r\n        </div>\r\n        \r\n        <h3>Convert Between Time Zones</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"timezone-from\">From</label>\r\n            <select id=\"timezone-from\">\r\n              <option value=\"America/New_York\">New York</option>\r\n              <option value=\"Europe/London\">London</option>\r\n              <option value=\"Asia/Tokyo\">Tokyo</option>\r\n              <option value=\"Australia/Sydney\">Sydney</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"timezone-to\">To</label>\r\n            <select id=\"timezone-to\">\r\n              <option value=\"America/New_York\">New York</option>\r\n              <option value=\"Europe/London\" selected=\"\">London</option>\r\n              <option value=\"Asia/Tokyo\">Tokyo</option>\r\n              <option value=\"Australia/Sydney\">Sydney</option>\r\n            </select>\r\n          </div>\r\n          <button id=\"convert-timezone-btn\">Convert</button>\r\n        </div>\r\n        \r\n        <div class=\"result\">\r\n          <pre id=\"timezone-result\"></pre>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Date/Time Arithmetic Section -->\r\n      <div id=\"arithmetic\" class=\"section\">\r\n        <h2>Date/Time Arithmetic</h2>\r\n        <p>Perform arithmetic operations on dates and times.</p>\r\n        \r\n        <div class=\"form-group\">\r\n          <label for=\"arithmetic-datetime\">DateTime (ISO String)</label>\r\n          <input type=\"text\" id=\"arithmetic-datetime\" value=\"2023-01-01T12:00:00\">\r\n        </div>\r\n        \r\n        <h3>Add to DateTime</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"add-years\">Years</label>\r\n            <input type=\"number\" id=\"add-years\" value=\"0\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"add-months\">Months</label>\r\n            <input type=\"number\" id=\"add-months\" value=\"0\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"add-days\">Days</label>\r\n            <input type=\"number\" id=\"add-days\" value=\"0\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"add-hours\">Hours</label>\r\n            <input type=\"number\" id=\"add-hours\" value=\"0\">\r\n          </div>\r\n          <button id=\"add-datetime-btn\">Add</button>\r\n        </div>\r\n        \r\n        <h3>Compare DateTimes</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"compare-datetime1\">DateTime 1</label>\r\n            <input type=\"text\" id=\"compare-datetime1\" value=\"2023-01-01T12:00:00\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"compare-datetime2\">DateTime 2</label>\r\n            <input type=\"text\" id=\"compare-datetime2\" value=\"2023-01-02T12:00:00\">\r\n          </div>\r\n          <button id=\"compare-datetime-btn\">Compare</button>\r\n        </div>\r\n        \r\n        <div class=\"result\">\r\n          <pre id=\"arithmetic-result\"></pre>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Durations Section -->\r\n      <div id=\"duration\" class=\"section\">\r\n        <h2>Durations</h2>\r\n        <p>Work with time durations in Temporal.</p>\r\n        \r\n        <h3>Create Duration</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"duration-days\">Days</label>\r\n            <input type=\"number\" id=\"duration-days\" value=\"0\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"duration-hours\">Hours</label>\r\n            <input type=\"number\" id=\"duration-hours\" value=\"0\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"duration-minutes\">Minutes</label>\r\n            <input type=\"number\" id=\"duration-minutes\" value=\"0\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"duration-seconds\">Seconds</label>\r\n            <input type=\"number\" id=\"duration-seconds\" value=\"0\">\r\n          </div>\r\n          <button id=\"create-duration-btn\">Create</button>\r\n        </div>\r\n        \r\n        <h3>Duration Between DateTimes</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"duration-start\">Start DateTime</label>\r\n            <input type=\"text\" id=\"duration-start\" value=\"2023-01-01T12:00:00\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"duration-end\">End DateTime</label>\r\n            <input type=\"text\" id=\"duration-end\" value=\"2023-01-02T18:30:45\">\r\n          </div>\r\n          <button id=\"calculate-duration-btn\">Calculate</button>\r\n        </div>\r\n        \r\n        <div class=\"result\">\r\n          <pre id=\"duration-result\"></pre>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Calendars Section -->\r\n      <div id=\"calendar\" class=\"section\">\r\n        <h2>Calendars</h2>\r\n        <p>Explore different calendar systems in Temporal.</p>\r\n        \r\n        <div class=\"form-group\">\r\n          <label for=\"calendar-date\">Date (ISO String)</label>\r\n          <input type=\"text\" id=\"calendar-date\" value=\"2023-01-01\">\r\n        </div>\r\n        \r\n        <div class=\"form-group\">\r\n          <label for=\"calendar-system\">Calendar System</label>\r\n          <select id=\"calendar-system\">\r\n            <option value=\"iso8601\">ISO 8601</option>\r\n            <option value=\"hebrew\">Hebrew</option>\r\n            <option value=\"islamic\">Islamic</option>\r\n            <option value=\"japanese\">Japanese</option>\r\n            <option value=\"buddhist\">Buddhist</option>\r\n            <option value=\"persian\">Persian</option>\r\n            <option value=\"indian\">Indian</option>\r\n            <option value=\"coptic\">Coptic</option>\r\n            <option value=\"ethiopic\">Ethiopic</option>\r\n            <option value=\"chinese\">Chinese</option>\r\n          </select>\r\n        </div>\r\n        \r\n        <button id=\"convert-calendar-btn\">Convert</button>\r\n        \r\n        <div class=\"result\">\r\n          <pre id=\"calendar-result\"></pre>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Practical Examples Section -->\r\n      <div id=\"practical\" class=\"section\">\r\n        <h2>Practical Examples</h2>\r\n        <p>Real-world examples using the Temporal API.</p>\r\n        \r\n        <h3>Calculate Age</h3>\r\n        <div class=\"form-group\">\r\n          <label for=\"birth-date\">Birth Date</label>\r\n          <input type=\"text\" id=\"birth-date\" value=\"1990-01-01\">\r\n        </div>\r\n        <button id=\"calculate-age-btn\">Calculate Age</button>\r\n        \r\n        <h3>Business Days Calculator</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"business-start\">Start Date</label>\r\n            <input type=\"text\" id=\"business-start\" value=\"2023-01-01\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"business-end\">End Date</label>\r\n            <input type=\"text\" id=\"business-end\" value=\"2023-01-31\">\r\n          </div>\r\n          <button id=\"calculate-business-days-btn\">Calculate</button>\r\n        </div>\r\n        \r\n        <h3>Flight Time Calculator</h3>\r\n        <div class=\"form-group\">\r\n          <label for=\"flight-departure\">Departure (ISO String with Time Zone)</label>\r\n          <input type=\"text\" id=\"flight-departure\" value=\"2023-01-01T08:30:00-05:00[America/New_York]\">\r\n        </div>\r\n        <div class=\"form-group\">\r\n          <label for=\"flight-duration-hours\">Flight Duration (Hours)</label>\r\n          <input type=\"number\" id=\"flight-duration-hours\" value=\"7\">\r\n        </div>\r\n        <div class=\"form-group\">\r\n          <label for=\"flight-duration-minutes\">Flight Duration (Minutes)</label>\r\n          <input type=\"number\" id=\"flight-duration-minutes\" value=\"45\">\r\n        </div>\r\n        <div class=\"form-group\">\r\n          <label for=\"flight-arrival-timezone\">Arrival Time Zone</label>\r\n          <select id=\"flight-arrival-timezone\">\r\n            <option value=\"Europe/London\">London</option>\r\n            <option value=\"Europe/Paris\">Paris</option>\r\n            <option value=\"Asia/Tokyo\">Tokyo</option>\r\n            <option value=\"Australia/Sydney\">Sydney</option>\r\n          </select>\r\n        </div>\r\n        <button id=\"calculate-flight-btn\">Calculate Arrival</button>\r\n        \r\n        <div class=\"result\">\r\n          <pre id=\"practical-result\"></pre>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Time Tracker Section -->\r\n      <div id=\"timetracker\" class=\"section\">\r\n        <h2>Time Tracker</h2>\r\n        <p>Track time using Temporal API</p>\r\n        \r\n        <h3>Current Time</h3>\r\n        <div class=\"result\">\r\n          <pre id=\"current-time-display\"></pre>\r\n        </div>\r\n        \r\n        <h3>Time Tracker</h3>\r\n        <div class=\"form-group\">\r\n          <label for=\"time-entry-timezone\">Time Zone</label>\r\n          <select id=\"time-entry-timezone\">\r\n            <option value=\"America/New_York\">New York</option>\r\n            <option value=\"America/Chicago\" selected=\"\">Chicago</option>\r\n            <option value=\"America/Denver\">Denver</option>\r\n            <option value=\"America/Los_Angeles\">Los Angeles</option>\r\n            <option value=\"Europe/London\">London</option>\r\n            <option value=\"Europe/Paris\">Paris</option>\r\n            <option value=\"Asia/Tokyo\">Tokyo</option>\r\n          </select>\r\n        </div>\r\n        <div class=\"button-group\">\r\n          <button id=\"start-tracking-btn\">Start Tracking</button>\r\n          <button id=\"stop-tracking-btn\" disabled=\"\">Stop Tracking</button>\r\n          <button id=\"reset-tracking-btn\">Reset</button>\r\n        </div>\r\n        \r\n        <h3>Tracking Information</h3>\r\n        <div class=\"result\">\r\n          <pre id=\"tracking-info\"></pre>\r\n        </div>\r\n        \r\n        <h3>Save Time Entry with Note</h3>\r\n        <div class=\"form-group\">\r\n          <label for=\"time-entry-note\">Note</label>\r\n          <textarea id=\"time-entry-note\" placeholder=\"Enter a note for this time entry\"></textarea>\r\n        </div>\r\n        <button id=\"save-with-note-btn\">Save Time Entry</button>\r\n        \r\n        <h3>Saved Time Entries</h3>\r\n        <div class=\"saved-entries-container\">\r\n          <table id=\"saved-entries-table\">\r\n            <thead>\r\n              <tr>\r\n                <th>Time</th>\r\n                <th>Note</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody id=\"saved-entries-body\">\r\n              <!-- Saved entries will be added here dynamically -->\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n        \r\n        <h3>Duration Calculation</h3>\r\n        <div class=\"inline-form\">\r\n          <div class=\"form-group\">\r\n            <label for=\"duration-start\">Start Time</label>\r\n            <input type=\"text\" id=\"duration-start\" placeholder=\"YYYY-MM-DDThh:mm:ss\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"duration-end\">End Time</label>\r\n            <input type=\"text\" id=\"duration-end\" placeholder=\"YYYY-MM-DDThh:mm:ss\">\r\n          </div>\r\n          <button id=\"calculate-duration-btn\">Calculate</button>\r\n        </div>\r\n        \r\n        <div class=\"result\">\r\n          <pre id=\"timetracker-result\"></pre>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  \r\n  <script src=\"/ddf1176e90e87b5a4ba165821f2dbe0b.js\"></script>\r\n</body>\r\n</html>\r\n"},"sourceMaps":null,"error":null,"hash":"f39ffd450647365ba80e8b9340ff7af7","cacheData":{"env":{}}}